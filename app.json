{
  "expo": {
    "name": "BookaWaka Driver",
    "slug": "taxi360-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bookawakadriver",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookawaka.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BookaWaka Driver needs your location for dispatch and navigation.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "BookaWaka Driver tracks location in the background while you are online or on a job.",
        "NSLocationAlwaysUsageDescription": "BookaWaka Driver tracks location in the background while you are online or on a job.",
        "UIBackgroundModes": ["location", "fetch", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.bookawaka.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BookaWaka Driver needs background location for dispatch.",
          "locationWhenInUsePermission": "BookaWaka Driver needs your location for dispatch.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a73e8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8cf080aa-8fbc-4bce-b653-6c865d1db592",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8cf080aa-8fbc-4bce-b653-6c865d1db592"
      },
      "dispatchApiUrl": "https://invt-production.up.railway.app"
    },
    "owner": "lovesaf"
  }
}
