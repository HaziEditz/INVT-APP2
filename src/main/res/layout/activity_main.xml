<?xml version="1.0" encoding="utf-8"?>
<android.support.v4.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_main"
    android:keepScreenOn="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity.MainActivity">

    <LinearLayout
        android:background="#ff232c33"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:visibility="gone"
            android:id="@+id/iv_openDrawer_main"
            android:layout_centerVertical="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/opendrawer_icon"/>
        <TextView
            android:visibility="gone"
            android:id="@+id/txt_main_username_Nm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="#fff"
            android:textSize="25dp"
            android:layout_marginTop="50dp"
            android:layout_centerHorizontal="true" />
        <ImageView
            android:id="@+id/iv"
            android:paddingTop="50dp"
            android:paddingLeft="100dp"
            android:paddingRight="100dp"
            android:layout_alignParentTop="true"
            android:layout_width="wrap_content"
            android:layout_height="170dp"
            android:src="@mipmap/logo_splash"
            android:layout_centerHorizontal="true" />


        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/iv"
            android:layout_above="@+id/lv_mainactivity_navdrawer"
            android:background="@android:color/transparent"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="5dp"
            >

            <LinearLayout
                android:id="@+id/driver_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:layout_marginTop="5dp"
                android:clickable="true"
                android:layout_marginLeft="5dp"
                android:background="@drawable/gridcell"
                android:foreground="?android:attr/selectableItemBackground"                android:backgroundTint="@color/colorGridCells"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:padding="25dp">

                <ImageView
                    android:id="@+id/iv_driverimage"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top"
                    android:scaleType="fitXY"
                    android:src="@drawable/driver" />

                <TextView
                    android:id="@+id/txt_main_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:text="Abdul Jalil"
                    android:textColor="#fff"
                    android:textSize="16dp" />
            </LinearLayout>

        </LinearLayout>


        <GridView
            android:id="@+id/lv_mainactivity_navdrawer1"
            android:layout_below="@id/iv"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="5dp"
            android:numColumns="3"
            android:drawSelectorOnTop="true"
            android:background="@drawable/grivdviewcorners"
            android:layout_above="@+id/txt_driverStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/data_navdrawer"></GridView>


    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        >
        <TextView
            android:visibility="visible"
            android:id="@+id/txt_driverStatus"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:text="Available"
            android:textColor="#fff"
            android:gravity="center"
            android:layout_gravity="bottom"
            android:background="#88a903"/>

    </LinearLayout>

    <LinearLayout
        android:visibility="gone"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:elevation="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorDarkBackground">
        <ImageView
            android:padding="30dp"
            android:src="@drawable/icon_navdrawer"
            android:background="@color/colorPrimary"
            android:layout_width="match_parent"
            android:layout_height="104dp"/>
        <TextView
            android:id="@+id/txt_main_navdrawer_username1"
            android:textColor="#fff"
            android:paddingLeft="16dp"
            android:background="@color/colorPrimaryDark"
            android:text="User Name"
            android:textSize="20dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="56dp" />
    </LinearLayout>


</android.support.v4.widget.DrawerLayout>
