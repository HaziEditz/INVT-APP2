<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_start_shift"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StartShift.StartShift"
    android:background="@color/colorDarkBackground">

    <android.support.v7.widget.Toolbar
        app:contentInsetStartWithNavigation="0dp"
        app:titleTextColor="#fff"
        android:elevation="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:theme="?attr/actionBarTheme"
        android:minHeight="?attr/actionBarSize"
        android:id="@+id/toolbar_signin" />

    <LinearLayout
        android:layout_below="@id/toolbar_signin"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:background="@drawable/gridcell"
            android:backgroundTint="@color/colorGridCells"
            android:layout_marginLeft="10dp">
            <TextView
                android:layout_gravity="center"
                android:gravity="bottom"
                android:textSize="20dp"
                android:layout_width="wrap_content"
                android:textColor="#fff"
                android:layout_height="wrap_content"
                android:drawableLeft="@drawable/clock"
                android:drawablePadding="5dp"
                android:text="Date"
                />
            <TextView
                android:id="@+id/txt_startShift_date"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:layout_marginLeft="10dp"
                android:textSize="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13/12/2016"
                android:textColor="#fff"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:orientation="horizontal"
            android:layout_marginRight="10dp"
            android:layout_marginTop="-10dp"
            android:background="@drawable/gridcell"
            android:backgroundTint="@color/colorGridCells"
            android:layout_marginLeft="10dp">
            <TextView
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:textSize="20dp"
                android:drawableLeft="@drawable/clock"
                android:drawablePadding="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textColor="#fff"/>
            <TextView
                android:id="@+id/txt_startShift_time"
                android:layout_marginLeft="5dp"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:textSize="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1:31 AM"
                android:textColor="#fff"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/gridcell"
            android:backgroundTint="@color/colorGridCells"
            android:weightSum="10"
            android:orientation="horizontal">

            <Spinner
                android:layout_weight="5"
                android:popupBackground="@color/colorDarkBackground"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:id="@+id/spinner_start_shift"
                android:backgroundTint="#fff"></Spinner>

            <ImageView
                android:id="@+id/imagedropdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="5"
                android:layout_marginRight="4dp"
                android:src="@drawable/dropdownarrow" />

        </LinearLayout>

        <!-- orignal spinner here
                <Spinner
                    android:visibility="gone"
                    android:popupBackground="@color/colorDarkBackground"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textsize="20dp"
                    android:background="@drawable/clock"
                    android:id="@+id/spinner_start_shiftbackup"
                    android:backgroundTint="#fff"></Spinner>
        -->


    </LinearLayout>
    <TextView
        android:id="@+id/selected_vh_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select A vehicle"
        android:textSize="30dp"
        android:background="@drawable/gridcell"
        android:gravity="center_vertical"
        android:textColor="#fff"
        android:paddingLeft="10dp"
        android:backgroundTint="@color/colorGridCells"
        android:layout_above="@+id/btn_startshift_selectVehicle"
        android:layout_margin="10dp"
        />
    <Button
        android:id="@+id/btn_startshift_selectVehicle"
        android:textColor="#fff"
        android:text="Select Vehicle"
        android:layout_marginBottom="20dp"
        android:background="@drawable/gridcell"
        android:backgroundTint="@color/colorGridCells"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="10dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:layout_marginRight="10dp"
        android:layout_width="match_parent"
        android:layout_height="40dp" />
</RelativeLayout>
