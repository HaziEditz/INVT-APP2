<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <android.support.v7.widget.CardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="5dp"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="25dp"
                android:orientation="horizontal"
                android:background="@color/cardview_dark_background"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textColor="#ffff"
                    android:gravity="center"
                    android:layout_marginLeft="5dp"
                    android:text="Booking"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textColor="#ffff"
                    android:gravity="center"
                    android:layout_marginLeft="5dp"
                    android:text="#0000"
                    android:id="@+id/txt_currentjob_booking_id"
                    />


            </LinearLayout>

            <LinearLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:orientation="horizontal" android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                <LinearLayout
                    android:layout_width="198dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="-5dp"
                        android:gravity="center_vertical"
                        android:drawableLeft="@drawable/people"
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:text=" PASSENGER NAME"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="#000000" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="-5dp"

                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/txt_currentjob_passenger_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:textSize="15dp"
                            android:text="DUMI NAME" />

                    </LinearLayout>

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="-5dp"
                        android:gravity="center_vertical"
                        android:drawableLeft="@drawable/info"
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:text=" PASSENGER CONTACT"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="#000000" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="-5dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/txt_currentjob_passenger_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:textSize="15dp"
                            android:text="Not Yet Assigned" />

                    </LinearLayout>

                </LinearLayout>


            </LinearLayout>

            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="#d3d2d2" />


            <LinearLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:orientation="horizontal" android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                <LinearLayout
                    android:id="@+id/datetime"
                    android:layout_width="198dp"

                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="-5dp"
                        android:gravity="center_vertical"
                        android:drawableLeft="@drawable/clock"
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:text=" DATE AND TIME"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="#000000" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="-5dp"

                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/txt_currentjob_booking_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:textSize="15dp"
                            android:text="As soon" />
                        <TextView
                            android:id="@+id/txt_currentjob_booking_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="2dp"
                            android:textSize="15dp"
                            android:text="as possible" />
                    </LinearLayout>

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/statusbooking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="-5dp"
                        android:gravity="center_vertical"
                        android:drawableLeft="@drawable/info"
                        android:textSize="10dp"
                        android:textStyle="bold"
                        android:text=" STATUS"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="#000000" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="-5dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/txt_currentjob_booking_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:textSize="15dp"
                            android:text="Not Yet Assigned" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="#d3d2d2" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:background="#ffffff"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="5dp"
                        android:orientation="vertical"
                        android:id="@+id/linearLayout">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="10dp"
                            android:drawableLeft="@drawable/pickup"
                            android:textStyle="bold"
                            android:text=" PICK UP LOCATION"
                            android:textAppearance="?android:attr/textAppearanceMedium"
                            android:textColor="#ff4f8f1d" />

                        <TextView
                            android:id="@+id/txt_currentjob_pick_addr"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="10dp"
                            android:layout_marginLeft="20dp"
                            android:text="Your pick up location" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#ffffff"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="-5dp"
                        android:orientation="vertical"
                        >

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="10dp"
                            android:drawableLeft="@drawable/pickup"
                            android:textStyle="bold"
                            android:text=" PICK UP LAT LONG"
                            android:textAppearance="?android:attr/textAppearanceMedium"
                            android:textColor="#ff4f8f1d" />

                        <TextView
                            android:id="@+id/txt_currentjob_pick_latlong"
                            android:layout_width="153dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="10dp"
                            android:layout_marginLeft="20dp"
                            android:text="Your pick up location" />
                    </LinearLayout>


                </LinearLayout>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layoutDestinationMybooking"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:drawableLeft="@drawable/linedown"/>


                        </LinearLayout>


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textSize="10dp"
                            android:textStyle="bold"
                            android:drawableLeft="@drawable/destination"
                            android:text=" DESTINATION"
                            android:textAppearance="?android:attr/textAppearanceMedium"
                            android:textColor="#ff9b0000" />

                        <TextView
                            android:id="@+id/txt_currentjob_drop_addr"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:textSize="10dp"
                            android:layout_marginLeft="20dp"
                            android:text="Pick your destination" />



                    </LinearLayout>

                    <LinearLayout

                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"

                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_marginTop="15dp"
                            android:layout_height="wrap_content">


                        </LinearLayout>


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textSize="10dp"
                            android:textStyle="bold"
                            android:drawableLeft="@drawable/destination"
                            android:text=" DESTINATION LAT LONG"
                            android:textAppearance="?android:attr/textAppearanceMedium"
                            android:textColor="#ff9b0000" />

                        <TextView
                            android:id="@+id/txt_currentjob_drop_latlong"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="10dp"
                            android:layout_marginLeft="20dp"
                            android:text="Pick your destination" />


                    </LinearLayout>


                </LinearLayout>


                <View
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:background="#d3d2d2" />



            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >
            <LinearLayout
                android:layout_width="196dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="2dp"
                    android:text="  COMPANY DISCOUNT"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    android:drawableLeft="@drawable/company"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="#000000" />

                <TextView
                    android:id="@+id/txt_currentjob_company_discount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:textSize="12dp"
                    android:layout_marginTop="1dp"
                    android:text=" Select taxi company" />



                <View
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:background="#d3d2d2" />


            </LinearLayout>
            <LinearLayout
                android:id="@+id/layoutCompanyMakeAbooking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="2dp"
                    android:text="  DRIVER DISCOUT"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    android:drawableLeft="@drawable/company"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="#000000" />

                <TextView
                    android:id="@+id/txt_currentjob_driver_discount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:textSize="12dp"
                    android:layout_marginTop="1dp"
                    android:text=" Select taxi company" />



                <View
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:background="#d3d2d2" />


            </LinearLayout>

        </LinearLayout>
            <LinearLayout
                android:id="@+id/layoutVehicleDetailsMakeAbooking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="5dp"
                >




                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:drawableLeft="@drawable/people"
                        android:textSize="12dp"
                        android:layout_marginTop="10dp"
                        android:text="Passengers:" />

                    <TextView
                        android:id="@+id/txt_currentjob_passengers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="20dp"
                        android:text="0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:drawableLeft="@drawable/bag"
                        android:text="Bags:"
                        android:textSize="12dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_currentjob_bags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="20dp"
                        android:text="0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="12dp"
                        android:drawableLeft="@drawable/wheelchair"
                        android:text="Wheel chairs:"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_currentjob_wheelchairs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="20dp"
                        android:text="0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="164dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="12dp"
                        android:drawableLeft="@drawable/vehicle"
                        android:text=" Booking Type:"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_currentjob_booking_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="20dp"
                        android:text="0" />
                </LinearLayout>


            </LinearLayout>

            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="#d3d2d2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="5dp"
                >




                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:drawableLeft="@drawable/dollar"
                        android:textSize="12dp"
                        android:layout_marginTop="10dp"
                        android:text="Payment type:" />

                    <TextView
                        android:id="@+id/txt_currentjob_payment_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="20dp"
                        android:text="0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:drawableLeft="@drawable/clock"
                        android:text="  Estimated time:"
                        android:textSize="12dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_currentjob_estimated_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="19dp"
                        android:layout_marginTop="10dp"
                        android:text="0"
                        android:textSize="20dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="12dp"
                        android:drawableLeft="@drawable/vehicle"
                        android:text=" Estimated Distance:"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_currentjob_estimated_distance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="10dp"
                        android:textSize="20dp"
                        android:text="0" />
                </LinearLayout>



            </LinearLayout>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="10dp"
                    android:textSize="12dp"
                    android:drawableLeft="@drawable/vehicle"
                    android:text=" Booking Extra Info:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_currentjob_booking_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="10dp"
                    android:textSize="20dp"
                    android:text="Left Empty" />
            </LinearLayout>


            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="#d3d2d2" />
        </LinearLayout>

    </android.support.v7.widget.CardView>




</LinearLayout>