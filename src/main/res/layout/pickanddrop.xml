<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <android.support.v7.widget.CardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="2dp"
        app:contentPadding="10dp">
<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#ffffff"
            android:orientation="vertical"
            android:id="@+id/linearLayout">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#ffffff"
        android:orientation="vertical"
        android:foreground="?android:attr/selectableItemBackground"
        android:id="@+id/layout_addjob_pickaddress">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12dp"
                android:drawableLeft="@drawable/pickup"
                android:textStyle="bold"
                android:drawablePadding="5dp"
                android:text="Pick Up Location"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="#ff4f8f1d" />

            <TextView
                android:id="@+id/txt_pickaddr_pickup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textSize="12dp"
                android:drawablePadding="5dp"
                android:drawableLeft="@drawable/linedown"
                android:textStyle="bold"
                android:text="Your pick up location" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="33dp"
                android:textSize="12dp"
                android:textStyle="italic"
                android:drawablePadding="5dp"
                android:background="@android:color/transparent"
                android:layout_marginBottom="-12dp"
                android:drawableLeft="@drawable/linedown"
                android:drawableRight="@drawable/pen"
                android:hint="Enter extra information for the driver"
                />
            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="2dp"
                android:background="#d3d2d2" />
        </LinearLayout>
        <LinearLayout
                android:id="@+id/layout_addjob_dropaddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?android:attr/selectableItemBackground"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:drawableRight="@drawable/next"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:drawablePadding="5dp"
                    android:drawableLeft="@drawable/destination"
                    android:text="Destination"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="#ff9b0000" />

                <TextView
                    android:id="@+id/txt_dropaddr_pickup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12dp"
                    android:textStyle="bold"
                    android:layout_marginTop="5dp"
                    android:layout_marginLeft="20dp"
                    android:text="Pick your destination" />


                <View
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:background="#d3d2d2" />
            </LinearLayout>

        </LinearLayout>

</RelativeLayout>


    </android.support.v7.widget.CardView>


</LinearLayout>