<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <LinearLayout
        android:id="@+id/Layout_row_chat_incomming1"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/chat_cell"
        android:backgroundTint="#fff8f8f8"
        android:orientation="vertical">


    <LinearLayout
        android:id="@+id/Layout_row_chat_incomming"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:background="#fff8f8f8"
        android:backgroundTint="#fff8f8f8"

        android:orientation="vertical">

        <LinearLayout
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#dce2f7"
            android:orientation="horizontal"
            android:weightSum="10"

            >

            <TextView
                android:id="@+id/rdrivername"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="3"
                android:layout_marginLeft="10dp"
                android:drawablePadding="10dp"
                android:text="Jalil Khan"
                android:textColor="#000000"

                />

            <TextView
                android:id="@+id/rmsgtime"
                android:drawableRight="@drawable/clock"
                android:drawablePadding="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_weight="7"
                android:gravity="right"
                android:text="10:58:14"
                android:textColor="#000000" />

        </LinearLayout>

        <TextView
            android:id="@+id/txt_row_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentStart="true"
            android:layout_margin="-10dp"
            android:background="@drawable/chat_cell"
            android:backgroundTint="#e3f2ff"
            android:padding="15dp"
            android:text="TextView"
            android:textColor="#000000"
            android:textSize="18dp" />
    </LinearLayout>

</LinearLayout>

    <LinearLayout
        android:id="@+id/Layout_row_chat_outgoing"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:background="@drawable/chat_cell"
        android:backgroundTint="#fff8f8f8"
        android:orientation="vertical"
        android:layout_below="@+id/Layout_row_chat_incomming1"
        android:layout_alignParentEnd="true">

        <LinearLayout
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0053fa"
            android:orientation="horizontal"
            android:weightSum="10"

            >

            <TextView
                android:id="@+id/sdrivername"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:layout_weight="3"
                android:layout_marginLeft="10dp"
                android:drawablePadding="10dp"
                android:text="Majid Khan"
                android:textColor="#ffff"

                />

            <TextView
                android:id="@+id/smsgtime"
                android:drawableRight="@drawable/clock"
                android:drawablePadding="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_weight="7"
                android:gravity="right"
                android:text="10:58:14"
                android:textColor="#ffff" />

        </LinearLayout>

        <TextView
            android:id="@+id/txt_row_chat_outgoing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentEnd="true"
            android:layout_gravity="right"
            android:layout_margin="-10dp"
            android:background="@drawable/chat_cell"
            android:backgroundTint="#ff0083fa"
            android:padding="15dp"
            android:text="TextView"
            android:textColor="#fff"
            android:textSize="18dp" />


    </LinearLayout>

    <ProgressBar
        android:visibility="gone"
        android:id="@+id/pb_chat_inbox"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_below="@+id/Layout_row_chat_outgoing"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginRight="10dp"/>



</RelativeLayout>