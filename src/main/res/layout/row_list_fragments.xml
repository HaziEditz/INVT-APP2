<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView
xmlns:android="http://schemas.android.com/apk/res/android"
android:orientation="vertical"
xmlns:card_view="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:foreground="?android:attr/selectableItemBackground"
card_view:cardCornerRadius="5dp"
android:id="@+id/card_view12"
android:layout_marginLeft="15dp"
android:layout_marginRight="15dp"
android:layout_marginTop="10dp"
android:elevation="2dp"
    >
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_below="@+id/toolbar_MyAccountActivity"
    android:background="#ffffff"
    android:orientation="vertical"
    >
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ride Info"
        android:textSize="20dp"
        android:textColor="#000"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="5dp"
        />
    <View
        android:layout_width="wrap_content"
        android:layout_height="1dp"
        android:background="#d3d2d2"
        android:layout_marginTop="10dp"
        />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:id="@+id/linearLayout_updateProfile_MyAccountActivity">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Passenger Name"
            android:textColor="#000"
            android:drawableLeft="@drawable/people"
            android:drawablePadding="5dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:text="user@email.com"
            android:textColor="#000"
            android:id="@+id/txt_list_current_passengername"
            android:textAppearance="?android:attr/textAppearanceSmall" />
    </LinearLayout>
    <View
        android:layout_width="wrap_content"
        android:layout_height="1dp"
        android:background="#d3d2d2"
        android:layout_marginTop="10dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contact"
        android:textColor="#000"
        android:drawableLeft="@drawable/number"
        android:drawablePadding="5dp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:id="@+id/txt_list_current_passengercontact"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detail >>  "
        android:textStyle="bold"
        android:textColor="#ff3f3f3f"
        android:drawablePadding="-5dp"
        android:gravity="end"
        android:textSize="15dp"
        />
    <View
        android:layout_width="wrap_content"
        android:layout_height="1dp"
        android:background="#d3d2d2"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="10dp"
        />
    <TextView
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Booking id"
        android:background="#fff"
        android:id="@+id/txt_list_current_bookingid"/>

</LinearLayout>


</android.support.v7.widget.CardView>

