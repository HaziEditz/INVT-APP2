<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.khybertech.taxi360driver.JobView.OfferedJobDetail"
    >
    <android.support.v7.widget.Toolbar
        app:layout_scrollFlags="enterAlways"
        app:titleTextColor="#fff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:id="@+id/toolbar_offered_job_detail" >
        <TextView
            android:id="@+id/txt_offeredjob_bartimer"
            android:gravity="center"
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            android:text="00:00"
            android:textSize="30dp"
            />
</android.support.v7.widget.Toolbar>
    <LinearLayout
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:orientation="vertical"
        >
        <LinearLayout
            android:id="@+id/loadingbaroffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/toolbar_chat_conversation"
            android:gravity="center"
            >
            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                />

        </LinearLayout>

        <include layout="@layout/offeredjobdetail_cardview"/>

    </LinearLayout>

    <LinearLayout
        android:layout_alignParentBottom="true"
        android:id="@+id/l1"
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_height="wrap_content">
        <Button
            android:id="@+id/btn_accept_offeredjobdetail"
            android:background="@drawable/button_square"
            android:shadowRadius="20"
            android:textColor="#fff"
            android:backgroundTint="#88a903"
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACCEPT"/>
        <Button
            android:id="@+id/btn_reject_offeredjobdetail"
            android:background="@drawable/button_square"
            android:textColor="#fff"
            android:backgroundTint="#e8692b"
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REJECT"/>
    </LinearLayout>
</RelativeLayout>
