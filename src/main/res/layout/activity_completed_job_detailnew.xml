<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_booking_details"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.khybertech.taxi360driver.JobView.CompletedJobDetail">

    <android.support.v7.widget.Toolbar
        app:contentInsetStartWithNavigation="1dp"
        app:layout_scrollFlags="enterAlways"
        app:titleTextColor="#fff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        android:minHeight="?attr/actionBarSize"
        android:id="@+id/toolbar_bookingdetails_detail" />



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:orientation="vertical"
        >

        <include layout="@layout/mybookingdetailed_cardview"/>


    </LinearLayout>

    <LinearLayout
        android:layout_alignParentBottom="true"
        android:id="@+id/layout_1_bookingDetail"
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_height="wrap_content">
        <Button
            android:visibility="gone"
            android:id="@+id/btn_active_booking_details"
            android:background="@drawable/button_square"
            android:shadowRadius="20"
            android:textColor="#fff"
            android:backgroundTint="#88a903"
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIRM"/>
        <Button
            android:visibility="gone"
            android:id="@+id/btn_cancel_booking_details"
            android:background="@drawable/button_square"
            android:textColor="#fff"
            android:backgroundTint="#e8692b"
            android:layout_weight="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CANCEL"/>

    </LinearLayout>

</RelativeLayout>
