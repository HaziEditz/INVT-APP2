<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?android:attr/selectableItemBackground"
    android:id="@+id/card_view12"
    android:layout_marginBottom="10dp"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/toolbar_MyAccountActivity"
        android:background="#ffffff"
        android:orientation="vertical"
        >



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:id="@+id/linearLayout_updateProfile_MyAccountActivity">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="#000"
                android:drawableLeft="@drawable/people"
                android:drawablePadding="5dp"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:text="user@email.com"
                android:textColor="#000"
                android:id="@+id/txt_name_inbox"
                android:textAppearance="?android:attr/textAppearanceSmall" />
        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap here to Chat >>  "
            android:textStyle="bold"
            android:textColor="#8b8b8b"
            android:drawablePadding="-5dp"
            android:gravity="end"
            android:textSize="15dp"
            />
        <View
            android:layout_width="wrap_content"
            android:layout_height="1dp"
            android:background="#d3d2d2"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="10dp"
            />
        <TextView
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking id"
            android:background="#fff"
            android:id="@+id/txt_list_current_bookingid"/>

    </LinearLayout>


    <TextView
        android:visibility="gone"
        android:id="@+id/txt_unreadmessage_inbox"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp"
        android:textColor="#88a903"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nangial Khan"
        android:textSize="15sp"/>

    <TextView
        android:visibility="gone"
        android:id="@+id/txt_id_inbox"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp"
        android:textColor="#88a903"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nangial Khan"
        android:textSize="15sp"/>

    <TextView
        android:visibility="gone"
        android:id="@+id/txt_playerid_inbox"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="10dp"
        android:textColor="#88a903"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nangial Khan"
        android:textSize="15sp"/>

</android.support.v7.widget.CardView>
